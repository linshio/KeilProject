  11   1              TH1 = 0xFA;             //设定定时器重装值
  12   1              ET1 = 0;                //禁止定时器1中断
  13   1              TR1 = 1;                //启动定时器1
  14   1              EA = 1;
  15   1              ES = 1;
  16   1      }
  17          //发送数据
  18          void UART_SendByte(unsigned char Byte)
  19          {
  20   1              SBUF=Byte;
  21   1              while(TI==0);
  22   1              //TI复位
  23   1              TI=0;
  24   1      }


