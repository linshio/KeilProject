   1          #include <REGX52.H>
   2          
   3          //串口初始化
   4          void UartInit(void)             //4800bps@11.0592MHz
   5          {
   6   1              PCON &= 0x7F;           //波特率不倍速
   7   1              SCON = 0x50;            //8位数据,可变波特率
   8   1              TMOD &= 0x0F;           //清除定时器1模式位
   9   1              TMOD |= 0x20;           //设定定时器1为8位自动重装方式
