   1          #include <REGX52.H>
   2          //100微秒@11.0592MHz 定时器的初始化 100微秒执行一次
   3          void Time1_Init()
   4          {
   5   1        //TMOD=0x01;
   6   1        TMOD &= 0x0F;   //设置定时器模式 在不改变前四位的情况下将后四位清零
   7   1        TMOD |= 0x10;   //设置定时器模式 在不改变前四位的情况下将后四位改为0001
   8   1        TL1 = 0xA4;   //设置定时初值
   9   1        TH1 = 0xFF;   //设置定时初值
  10   1        TF1 = 0;    //清除TF0标志
  11   1        TR1 = 1;    //定时器0开始计时
  12   1        ET1=1;
  13   1        EA=1;
  14   1        PT1=0;
  15   1      }
