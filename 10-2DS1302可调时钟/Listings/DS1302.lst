  42   2                      DS1302_IO=Data&(0x01<<i);
  43   2                      DS1302_SCLK=1;
  44   2                      DS1302_SCLK=0;
  45   2              }
  46   1              DS1302_CE=0;
  47   1      }
  48          //向指定的地址读取数据
  49          unsigned char DS1302_ReadByte(unsigned char Commond)
