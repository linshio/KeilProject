  97   1              DS1302_Time[1] = Temp/16*10+Temp%16;
  98   1              Temp = DS1302_ReadByte(DS1302_DATE);
  99   1              DS1302_Time[2] = Temp/16*10+Temp%16;
 100   1              Temp = DS1302_ReadByte(DS1302_HOUR);
