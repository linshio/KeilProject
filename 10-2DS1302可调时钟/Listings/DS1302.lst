  75          void DS1302_SetTime(void)       
  76          {
  77   1              //解除写保护状态
  78   1              DS1302_WriteByte(DS1302_WP,0x00);
  79   1              //此处的计算为十进制编码转换为BCD编码
  80   1              DS1302_WriteByte(DS1302_YEAR,DS1302_Time[0]/10*16+DS1302_Time[0]%10);
  81   1              DS1302_WriteByte(DS1302_MONTH,DS1302_Time[1]/10*16+DS1302_Time[1]%10);
  82   1              DS1302_WriteByte(DS1302_DATE,DS1302_Time[2]/10*16+DS1302_Time[2]%10);
