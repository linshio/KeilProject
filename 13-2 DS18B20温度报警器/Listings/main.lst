  45   2          LCD_ShowChar(1,7,'.');
  46   2          LCD_ShowNum(1,8,(unsigned long)(TShow*100)%100,2);
  47   2          
  48   2          /*阈值判断及显示*/
  49   2          if(KeyNum)
  50   2          {
  51   3            if(KeyNum==1) {THigh++;if(THigh>125)THigh=125;}
  52   3            if(KeyNum==2) {THigh--;if(THigh<=TLow)THigh++;}
  53   3            if(KeyNum==3) {TLow++;if(THigh>=TLow)TLow--;}
  54   3            if(KeyNum==4) {TLow--;if(TLow<-55)TLow=-55;}
