  17   1        THigh=AT24C02_ReadByte(0);
  18   1        TLow=AT24C02_ReadByte(1);
  19   1        if(THigh>125||TLow<-55||THigh<=TLow){THigh=15;TLow=13;} 
  20   1        /*温度读取与显示*/
  21   1        LCD_Init();
