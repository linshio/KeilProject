  34   2          if(T<0)
  35   2          {
  36   3            LCD_ShowChar(1,3,'-');
  37   3            TShow=-T;
  38   3          }else
  39   2          {
  40   3            LCD_ShowChar(1,3,'+');
  41   3            TShow=T;
  42   3          }
  43   2          
