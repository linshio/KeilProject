   6          sbit SER = P3^4;//SER
   7          //写入74HC595一个字节
   8          void _74HC595_WriteByte(unsigned char Byte)
   9          {
  10   1              unsigned char i;
  11   1              for(i=0;i<8;i++)
  12   1              {
  13   2                      SER=Byte&(0x80>>i);
  14   2                      SCK=1;
  15   2                      SCK=0;
  16   2              }
  17   1              RCK=1;
  18   1              RCK=0;
  19   1      }
  20          
  21          //LED点阵屏显示一列数据
  22          //Column需要显示的列 范围0-7
  23          //Data每列需要显示的数据 高位在上，1为亮，0为灭
  24          void MatrixLED_ShowColumn(unsigned char Column,Data)
  25          {
  26   1              _74HC595_WriteByte(Data);
  27   1              MATRIX_LED_PORT=~(0x80>>Column);
  28   1              Delay(1);
  29   1              MATRIX_LED_PORT=0xFF;
  30   1      }
  31          //矩阵LED初始化参数
  32          void MatrixLED_Init()
  33          {
