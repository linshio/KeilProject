   1          #include <REGX52.H>
   2          #include "OneWire.h"
   3          //SKIP ROM [CCh]
   4          //CONVERT T [44h]
   5          //READ SCRATCHPAD [BEh]
   6          
   7          #define DS18B20_SKIP_ROM          0xCC
   8          #define DS18B20_CONVERT_T         0x44
   9          #define DS18B20_READ_SCRATCHPAD   0xBE
  10          
  11          /**
  12            * @brief  温度变换
  13            * @param  
  14            * @retval 
  15            */
  16          void DS18B20_ConverT(void)
