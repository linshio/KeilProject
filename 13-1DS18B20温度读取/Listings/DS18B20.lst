  27            */
  28          float DS18B20_ReadT(void)
  29          {
  30   1        unsigned char TLSB,TMSB;
  31   1        //临时变量
  32   1        int Temp;
  33   1        //温度值
  34   1        float T;
  35   1        OneWire_Init();
  36   1        OneWire_SendByte(DS18B20_SKIP_ROM);
  37   1        OneWire_SendByte(DS18B20_READ_SCRATCHPAD);
